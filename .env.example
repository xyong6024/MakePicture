PORT=3000
AI_PROVIDER=mock

# When AI_PROVIDER=http, the server will POST each image to this endpoint.
AI_API_URL=
AI_API_KEY=
AI_API_IMAGE_FIELD=image
AI_API_TIMEOUT_MS=120000

# Optional JSON strings:
# AI_API_HEADERS={"x-api-key":"demo"}
# AI_API_EXTRA_FIELDS={"style":"ecommerce","quality":"high"}
# AI_RESPONSE_BASE64_PATH=data.0.b64_json
# AI_RESPONSE_URL_PATH=data.0.url
AI_API_HEADERS=
AI_API_EXTRA_FIELDS=
AI_RESPONSE_BASE64_PATH=
AI_RESPONSE_URL_PATH=

# When AI_PROVIDER=openai-compatible, the server will call an OpenAI-style
# image generation gateway such as the user's relay site.
OPENAI_COMPAT_BASE_URL=https://cx.ll.sd
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-image-2
OPENAI_COMPAT_MODE=images-edits
OPENAI_COMPAT_IMAGES_EDIT_PATH=/v1/images/edits
OPENAI_COMPAT_RESPONSES_PATH=/v1/responses
OPENAI_COMPAT_FILES_PATH=/v1/files
OPENAI_COMPAT_QUALITY=high
OPENAI_COMPAT_OUTPUT_FORMAT=png
OPENAI_COMPAT_BACKGROUND=auto
OPENAI_COMPAT_PROMPT_PREFIX=
